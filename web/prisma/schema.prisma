generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  shop                        String
  id                          String
  mirrorBatchId               String
  deletedAt                   DateTime?
  title                       String
  handle                      String?
  status                      String
  productType                 String?
  vendor                      String?
  tags                        String[]
  templateSuffix              String?

  // split raw html from filterable text
  descriptionHtml             String?
  descriptionText             String?

  createdAt                   DateTime?
  updatedAt                   DateTime?
  publishedAt                 DateTime?
  seoTitle                    String?
  seoDescription              String?
  totalInventory              Int?
  categoryId                  String?
  categoryName                String?
  googleShoppingEnabled       Boolean?
  googleShoppingAgeGroup      String?
  googleShoppingCategory      String?
  googleShoppingColor         String?
  googleShoppingCondition     String?
  googleShoppingCustomLabel0  String?
  googleShoppingCustomLabel1  String?
  googleShoppingCustomLabel2  String?
  googleShoppingCustomLabel3  String?
  googleShoppingCustomLabel4  String?
  googleShoppingCustomProduct Boolean?
  googleShoppingGender        String?
  googleShoppingMpn           String?
  googleShoppingMaterial      String?
  googleShoppingSize          String?
  googleShoppingSizeSystem    String?
  googleShoppingSizeType      String?
  categoryAgeGroup            String?
  categoryColor               String?
  categoryFabric              String?
  categoryFit                 String?
  categorySize                String?
  categoryTargetGender        String?
  categoryWaistRise           String?
  featuredImageUrl            String?
  featuredImageAltText        String?
  optionsJson                 Json?
  collectionsJson             Json?
  option1Name                 String?
  option2Name                 String?
  option3Name                 String?
  variantCount                Int?      @default(0)
  visibleOnlineStore          Boolean?
  lastSourceUpdatedAt         DateTime?
  lastSourceEventAt           DateTime?
  lastSourceKind              String?
  lastReconciledAt            DateTime?
  variants                    Variant[]

  @@id([shop, id, mirrorBatchId])
  @@index([shop, mirrorBatchId])
  @@index([shop, status])
  @@index([shop, vendor])
  @@index([shop, productType])
  @@index([shop, title])
  @@index([shop, handle])
  @@index([shop, createdAt])
  @@index([shop, updatedAt])
  @@index([shop, publishedAt])
  @@index([shop, categoryName])
  @@index([shop, googleShoppingEnabled])
  @@index([shop, googleShoppingCategory])
  @@index([shop, googleShoppingCondition])
  @@index([shop, googleShoppingGender])
  @@index([shop, googleShoppingAgeGroup])
  @@index([shop, categoryColor])
  @@index([shop, categorySize])
  @@index([shop, categoryTargetGender])
  @@index([shop, templateSuffix])
  @@index([shop, option1Name])
  @@index([shop, option2Name])
  @@index([shop, option3Name])
  @@index([shop, variantCount])
  @@index([shop, visibleOnlineStore])
  @@index([shop, lastReconciledAt])
  @@index([shop, lastSourceEventAt])
  @@index([shop, lastSourceKind])
  @@index([shop, lastSourceUpdatedAt])
  @@index([shop, mirrorBatchId, categoryAgeGroup])
  @@index([shop, mirrorBatchId, categoryColor])
  @@index([shop, mirrorBatchId, categoryFabric])
  @@index([shop, mirrorBatchId, categoryFit])
  @@index([shop, mirrorBatchId, categoryName])
  @@index([shop, mirrorBatchId, categorySize])
  @@index([shop, mirrorBatchId, categoryTargetGender])
  @@index([shop, mirrorBatchId, categoryWaistRise])
  @@index([shop, mirrorBatchId, googleShoppingCategory])
  @@index([shop, mirrorBatchId, googleShoppingColor])
  @@index([shop, mirrorBatchId, googleShoppingCustomLabel0])
  @@index([shop, mirrorBatchId, googleShoppingCustomLabel1])
  @@index([shop, mirrorBatchId, googleShoppingCustomLabel2])
  @@index([shop, mirrorBatchId, googleShoppingCustomLabel3])
  @@index([shop, mirrorBatchId, googleShoppingCustomLabel4])
  @@index([shop, mirrorBatchId, googleShoppingMaterial])
  @@index([shop, mirrorBatchId, googleShoppingMpn])
  @@index([shop, mirrorBatchId, googleShoppingSize])
  @@index([shop, mirrorBatchId, option1Name])
  @@index([shop, mirrorBatchId, option2Name])
  @@index([shop, mirrorBatchId, option3Name])
  @@index([shop, mirrorBatchId, productType])
  @@index([shop, mirrorBatchId, vendor])

  // add this because search/filter now uses descriptionText
  @@index([shop, mirrorBatchId, descriptionText])
}

model Variant {
  shop                String
  id                  String
  productId           String
  mirrorBatchId       String
  deletedAt           DateTime?
  title               String?
  sku                 String?
  barcode             String?
  price               Float?
  compareAtPrice      Float?
  inventoryQuantity   Int?
  inventoryPolicy     String?
  taxable             Boolean?
  taxCode             String?
  position            Int?
  selectedOptionsJson Json?
  cost                Float?
  countryOfOrigin     String?
  hsTariffCode        String?
  weight              Float?
  weightUnit          String?
  option1Value        String?
  option2Value        String?
  option3Value        String?
  physicalProduct     Boolean?
  profitMargin        Float?
  tracked             Boolean?
  product             Product  @relation(fields: [shop, productId, mirrorBatchId], references: [shop, id, mirrorBatchId])

  @@id([shop, id, mirrorBatchId])
  @@index([shop, mirrorBatchId])
  @@index([shop, sku])
  @@index([shop, price])
  @@index([shop, productId])
  @@index([shop, barcode])
  @@index([shop, title])
  @@index([shop, compareAtPrice])
  @@index([shop, cost])
  @@index([shop, inventoryQuantity])
  @@index([shop, inventoryPolicy])
  @@index([shop, taxable])
  @@index([shop, weight])
  @@index([shop, weightUnit])
  @@index([shop, countryOfOrigin])
  @@index([shop, hsTariffCode])
  @@index([shop, option1Value])
  @@index([shop, option2Value])
  @@index([shop, option3Value])
  @@index([shop, tracked])
  @@index([shop, physicalProduct])
  @@index([shop, profitMargin])
  @@index([shop, mirrorBatchId, countryOfOrigin])
  @@index([shop, mirrorBatchId, inventoryPolicy])
  @@index([shop, mirrorBatchId, option1Value])
  @@index([shop, mirrorBatchId, option2Value])
  @@index([shop, mirrorBatchId, option3Value])
  @@index([shop, mirrorBatchId, weightUnit])
}

model SpreadsheetFile {
  id             String   @id @default(cuid())
  shop           String?
  editHistoryId  String?
  fileUrl        String?
  columnMappings Json?
  totalRows      Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([shop])
}

model Store {
  id                              String            @id @default(cuid())
  shopUrl                         String            @unique
  shopEmail                       String
  accessToken                     String?
  activeMirrorBatchId             String?
  mirrorSchemaVersion             Int               @default(1)
  activeCollectionBatchId         String?
  isCollectionSyncing             Boolean           @default(false)
  lastCollectionSyncAt            DateTime?
  isProductTypeSyncing            Boolean           @default(false)
  lastProductTypeSyncAt           DateTime?
  isProductInitialySyning         Boolean           @default(false)
  productInitialSyncProgress      Int               @default(0)
  syncProgressStage               SyncProgressStage @default(IDLE)
  shopifyBulkJobCompleted         Boolean           @default(false)
  storeTotalProducts              Int               @default(0)
  isProductSyncing                Boolean           @default(false)
  lastProductSyncAt               DateTime?
  mirrorHealthState               MirrorHealthState @default(HEALTHY)
  staleReason                     String?
  repairRequired                  Boolean           @default(false)
  lastFullSyncAt                  DateTime?
  lastIncrementalSyncAt           DateTime?
  lastWebhookProcessedAt          DateTime?
  lastReconcileAt                 DateTime?
  lastInventoryReconcileAt        DateTime?
  lastCollectionReconcileAt       DateTime?
  mirrorUnsafeSince               DateTime?
  lastSyncErrorSummary            String?
  scope                           String?           @default("")
  installedAt                     DateTime?
  unInstalledAt                   DateTime?
  isUnInstalled                   Boolean           @default(false)
  referralCode                    String?           @unique
  referralLink                    String?           @unique
  referredBy                      String?
  refIsFirstSubscriptionCompleted Boolean           @default(false)
  refSubscribedDate               DateTime?
  refRewardExpiresAt              DateTime?
  refRewarded                     Boolean           @default(false)
  refSubscribedPlanDetails        Json?
  refEarnedPrice                  Float             @default(0)
  isCreditAvailable               Boolean           @default(false)
  lastActivityAt                  DateTime?
  createdAt                       DateTime          @default(now())
  updatedAt                       DateTime          @updatedAt

  @@index([isProductSyncing])
  @@index([lastProductSyncAt])
  @@index([isCollectionSyncing])
  @@index([lastCollectionSyncAt])
  @@index([lastProductTypeSyncAt])
  @@index([referralCode])
  @@index([referredBy])
  @@index([lastActivityAt])
  @@index([isUnInstalled])
  @@index([installedAt])
  @@index([createdAt])
}

model Subscription {
  id                    String             @id @default(cuid())
  shop                  String             @unique
  planKey               String?
  planName              String?
  subscriptionId        String?
  status                SubscriptionStatus @default(FREE)
  pendingSubscriptionId String?
  pendingPlanKey        String?
  pendingPlanName       String?
  trialEndsAt           DateTime?
  currentPeriodEnd      DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([shop])
}

model Suggestion {
  id         String   @id @default(cuid())
  email      String
  suggestion String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([email])
}

model SyncHistory {
  id                   String             @id @default(cuid())
  shop                 String
  bulkOperationId      String?
  syncBatchId          String?
  responseUrl          String?
  status               SyncStatus         @default(processing)
  stage                String?
  errorMessage         String?
  duration             Int?               @default(0)
  recordCount          Int?
  operationType        SyncOperationType?
  isInitialProductSync Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  executionState       String             @default("planned")
  executionIdentity    String?
  lastHeartbeatAt      DateTime?
  completedAt          DateTime?

  @@index([shop, createdAt])
  @@index([shop, status])
  @@index([shop, operationType])
  @@index([shop, executionState])
}

model EditHistory {
  id                        String                 @id @default(cuid())
  shop                      String
  bulkOperationId           String?
  executionState            String                 @default("planned")
  executionIdentity         String?                @unique
  targetSnapshotCount       Int                    @default(0)
  targetMirrorBatchId       String?
  failureStage              String?
  title                     Json?
  queryFilter               String                 @default("")
  editedType                String?
  rules                     Json?
  affectedFields            Json?
  locationId                String?
  status                    String                 @default("pending")
  scheduledAt               DateTime?
  scheduledUndoAt           DateTime?
  processedCount            Int                    @default(0)
  totalItems                Int                    @default(0)
  totalRows                 Int                    @default(0)
  durationMs                Int                    @default(0)
  editTime                  DateTime               @default(now())
  startedAt                 DateTime
  completedAt               DateTime?
  undo                      Json?
  undoState                 String?
  undoExecutionIdentity     String?
  undoQueuedAt              DateTime?
  undoStartedAt             DateTime?
  undoCompletedAt           DateTime?
  undoBulkOperationId       String?
  batch                     Json?
  type                      String?                @default("Manual edit")
  processingBatchId         String?
  scheduledTask             String?
  user                      String?
  isFavourite               Boolean                @default(false)
  isSpreadsheetEdit         Boolean                @default(false)
  isRecurring               Boolean                @default(false)
  recurringEditId           String?
  recurringRunId            String?
  automaticProductRuleId    String?
  automaticProductRuleRunId String?                @unique
  triggerType               EditHistoryTriggerType @default(MANUAL)
  error                     Json?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  filterVersion             Int?
  canonicalFilterKey        String?
  changeRecords             ChangeRecord[]

  @@index([shop, status, type, updatedAt], map: "shop_status_type_recent")
  @@index([shop])
  @@index([shop, executionState])
  @@index([isSpreadsheetEdit])
  @@index([recurringEditId])
  @@index([recurringRunId])
  @@index([automaticProductRuleId])
  @@index([automaticProductRuleRunId])
  @@index([shop, canonicalFilterKey])
}

model BulkUndoExecution {
  id                  String   @id @default(cuid())
  shop                String
  historyId           String
  executionIdentity   String   @unique
  state               String
  source              String
  frozenCount         Int      @default(0)
  processedCount      Int      @default(0)
  lastSnapshotOrdinal Int      @default(0)
  bulkOperationId     String?
  errorMessage        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([shop, historyId])
  @@index([shop, state])
}

model BulkUndoTargetSnapshot {
  id                String   @id @default(cuid())
  shop              String
  historyId         String
  executionIdentity String
  productId         String
  ordinal           Int
  changeHash        String
  createdAt         DateTime @default(now())

  @@unique([shop, executionIdentity, productId])
  @@unique([shop, executionIdentity, ordinal])
  @@index([shop, executionIdentity, ordinal])
  @@index([shop, historyId])
}

model RecurringEdit {
  id                 String                @id @default(cuid())
  shop               String
  title              String
  status             RecurringEditStatus   @default(ACTIVE)
  scheduleType       RecurringScheduleType
  timezone           String
  scheduleConfig     Json
  cronExpression     String?
  intervalMinutes    Int?
  startAt            DateTime?
  endAt              DateTime?
  filterParams       Json
  rules              Json
  runCount           Int                   @default(0)
  lastRunAt          DateTime?
  nextRunAt          DateTime?
  lastSuccessAt      DateTime?
  lastFailureAt      DateTime?
  lastFailureReason  String?
  isDeleted          Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  filterVersion      Int                   @default(1)
  canonicalFilterKey String?
  runs               RecurringEditRun[]

  @@index([shop])
  @@index([shop, status])
  @@index([shop, nextRunAt])
  @@index([nextRunAt])
  @@index([shop, canonicalFilterKey])
}

model RecurringEditRun {
  id              String                 @id @default(cuid())
  recurringEditId String
  shop            String
  scheduledFor    DateTime
  startedAt       DateTime?
  completedAt     DateTime?
  status          RecurringEditRunStatus @default(PENDING)
  executionKey    String                 @unique
  errorMessage    String?
  editHistoryId   String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  recurringEdit   RecurringEdit          @relation(fields: [recurringEditId], references: [id], onDelete: Cascade)

  @@index([recurringEditId])
  @@index([shop, status])
  @@index([shop, scheduledFor])
  @@index([editHistoryId])
}

model AutomaticProductRule {
  id                 String                             @id @default(cuid())
  shop               String
  title              String
  status             AutomaticProductRuleStatus         @default(ACTIVE)
  triggerType        AutomaticProductRuleTriggerType
  scheduleType       AutomaticRuleScheduleType?
  timezone           String?
  scheduleConfig     Json?
  cronExpression     String?
  intervalMinutes    Int?
  startAt            DateTime?
  endAt              DateTime?
  scopeType          AutomaticProductRuleScopeType
  scope              Json?
  conditions         Json
  actions            Json
  applyMode          String
  executionMode      String                             @default("REALTIME")
  conflictStrategy   String                             @default("PRIORITY_WINS")
  priority           Int                                @default(100)
  cooldownMinutes    Int?
  maxExecutionsPerHour Int?
  maxAffectedPerRun  Int?
  runCount           Int                                @default(0)
  lastRunAt          DateTime?
  nextRunAt          DateTime?
  lastSuccessAt      DateTime?
  lastFailureAt      DateTime?
  lastFailureReason  String?
  createdBy          String?
  updatedBy          String?
  isDeleted          Boolean                            @default(false)
  createdAt          DateTime                           @default(now())
  updatedAt          DateTime                           @updatedAt
  filterVersion      Int                                @default(1)
  canonicalFilterKey String?
  productStates      AutomaticProductRuleProductState[]
  runs               AutomaticProductRuleRun[]

  @@index([shop, status])
  @@index([shop, nextRunAt])
  @@index([shop, triggerType])
  @@index([shop, executionMode, status])
  @@index([shop, priority, status])
  @@index([shop, createdAt])
  @@index([shop, canonicalFilterKey])
}

model AutomaticProductRuleRun {
  id                     String                               @id @default(cuid())
  automaticProductRuleId String
  shop                   String
  triggerSource          AutomaticProductRuleRunTriggerSource
  triggerReference       String?
  scheduledFor           DateTime?
  startedAt              DateTime?
  completedAt            DateTime?
  status                 AutomaticProductRuleRunStatus        @default(PENDING)
  executionKey           String                               @unique
  matchedCount           Int                                  @default(0)
  affectedCount          Int                                  @default(0)
  errorMessage           String?
  editHistoryId          String?
  createdAt              DateTime                             @default(now())
  updatedAt              DateTime                             @updatedAt
  automaticProductRule   AutomaticProductRule                 @relation(fields: [automaticProductRuleId], references: [id], onDelete: Cascade)

  @@index([shop, status, createdAt])
  @@index([automaticProductRuleId, createdAt])
  @@index([automaticProductRuleId, scheduledFor])
  @@index([editHistoryId])
}

model AutomaticProductRuleProductState {
  id                     String               @id @default(cuid())
  automaticProductRuleId String
  shop                   String
  productId              String
  lastMatchedAt          DateTime?
  lastAppliedAt          DateTime?
  lastFingerprint        String?
  suppressedUntil        DateTime?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  automaticProductRule   AutomaticProductRule @relation(fields: [automaticProductRuleId], references: [id], onDelete: Cascade)

  @@unique([automaticProductRuleId, shop, productId])
  @@index([shop, productId])
  @@index([automaticProductRuleId, suppressedUntil])
}

model Rule {
  id               String        @id @default(cuid())
  shopId           String
  name             String
  description      String?
  status           RuleStatus
  mode             RuleMode
  priority         Int           @default(50)
  scopeType        String
  scopeRefId       String?
  filterDsl        Json
  actionDsl        Json
  conflictStrategy String
  allowDestructive Boolean       @default(false)
  cooldownSeconds  Int           @default(0)
  maxRunsPerHour   Int?
  lastRunAt        DateTime?
  lastRunHash      String?
  version          Int           @default(1)
  parentRuleId     String?
  createdBy        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?
  runs             RuleRun[]
  versions         RuleVersion[]
  schedules        RuleSchedule[]
  executionStats   RuleExecutionStat[]
  eventDedups      RuleEventDedup[]

  @@index([shopId, status])
  @@index([shopId, priority])
  @@index([shopId, id])
}

model RuleVersion {
  id           String   @id @default(cuid())
  shopId       String
  ruleId       String
  version      Int
  filterDsl    Json
  actionDsl    Json
  snapshotNote String?
  createdAt    DateTime @default(now())
  rule         Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, version])
  @@index([shopId, ruleId])
}

model RuleRun {
  id             String          @id @default(cuid())
  shopId         String
  ruleId         String
  operationId    String?
  triggerType    String
  triggerEventId String?
  status         RuleRunStatus
  catalogBatchId String
  targetCount    Int?
  affectedCount  Int?
  failureCount   Int?
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  errorCode      String?
  errorMessage   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  rule           Rule            @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  executions     RuleExecution[]
  failures       RuleFailure[]
  targetSnapshots RuleTargetSnapshot[]

  @@unique([shopId, ruleId, triggerEventId])
  @@index([shopId, ruleId])
  @@index([shopId, status])
  @@index([shopId, status, createdAt])
  @@index([shopId, catalogBatchId])
}

model RuleExecution {
  id        String   @id @default(cuid())
  shopId    String
  ruleRunId String
  entityType String
  entityId  String
  status    RuleExecutionStatus
  reason    String?
  createdAt DateTime @default(now())
  ruleRun   RuleRun  @relation(fields: [ruleRunId], references: [id], onDelete: Cascade)

  @@unique([ruleRunId, entityType, entityId])
  @@index([shopId, ruleRunId])
  @@index([ruleRunId, entityId])
}

model RuleFailure {
  id           String   @id @default(cuid())
  shopId       String
  ruleRunId    String
  entityType   String
  entityId     String
  errorCode    String
  errorMessage String?
  createdAt    DateTime @default(now())
  ruleRun      RuleRun  @relation(fields: [ruleRunId], references: [id], onDelete: Cascade)

  @@index([shopId, ruleRunId])
}

model RuleExecutionStat {
  id          String   @id @default(cuid())
  shopId      String
  ruleId      String
  windowStart DateTime
  runCount    Int
  createdAt   DateTime @default(now())
  rule        Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([shopId, ruleId, windowStart])
  @@index([shopId, ruleId])
}

model RuleSchedule {
  id        String   @id @default(cuid())
  shopId    String
  ruleId    String
  cron      String
  nextRunAt DateTime
  timezone  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  rule      Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([shopId, nextRunAt])
  @@index([shopId, ruleId])
}

model RuleEventDedup {
  id        String   @id @default(cuid())
  shopId    String
  ruleId    String
  eventId   String
  createdAt DateTime @default(now())
  rule      Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([shopId, ruleId, eventId])
  @@index([shopId, ruleId])
}

model RuleTargetSnapshot {
  id         String  @id @default(cuid())
  shopId     String
  ruleRunId  String
  entityType String
  entityId   String
  ruleRun    RuleRun @relation(fields: [ruleRunId], references: [id], onDelete: Cascade)

  @@unique([ruleRunId, entityType, entityId])
  @@index([shopId, ruleRunId])
  @@index([ruleRunId, entityId])
}

model ProductCodeSnippet {
  id                   String                              @id @default(cuid())
  shop                 String
  title                String
  status               ProductCodeSnippetStatus            @default(DRAFT)
  language             ProductCodeSnippetLanguage          @default(SNIPPET_DSL)
  code                 String
  normalizedAst        Json?
  lastValidationStatus ProductCodeSnippetValidationStatus?
  lastValidationError  String?
  lastPreviewedAt      DateTime?
  createdBy            String?
  updatedBy            String?
  isDeleted            Boolean                             @default(false)
  createdAt            DateTime                            @default(now())
  updatedAt            DateTime                            @updatedAt

  @@index([shop, status])
  @@index([shop, createdAt])
  @@index([shop, updatedAt])
}

model Collection {
  id            String   @id @default(cuid())
  shop          String?
  shopifyId     String?
  mirrorBatchId String?
  title         String?
  handle        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([updatedAt])
  @@index([shop, mirrorBatchId])
  @@index([shop, title])
  @@index([shop, mirrorBatchId, title])
}

model ExportHistory {
  id            String    @id @default(cuid())
  shop          String
  filename      String
  filters       Json
  exportedData  String?
  status        String
  duration      String
  totalItems    Int?
  errorMessage  String?
  exportTime    DateTime?
  type          String    @default("Manual export")
  isFavourite   Boolean   @default(false)
  scheduledTask String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@unique([scheduledTask])

  @@index([shop, createdAt])
  @@index([shop, status])
  @@index([shop, isFavourite])
  @@index([shop, type])
  @@index([shop, exportTime])
}

model ScheduledExport {
  id                 String                @id @default(cuid())
  shop               String
  title              String
  name               String?
  type               String                @default("PRODUCT_EXPORT")
  status             ScheduledExportStatus @default(ACTIVE)
  frequency          ScheduledExportFrequency?
  scheduleType       RecurringScheduleType
  timezone           String
  scheduleConfig     Json
  cronExpression     String?
  intervalMinutes    Int?
  startAt            DateTime?
  endAt              DateTime?
  filterParams       Json
  queryWhere         Json?
  productIds         Json?
  requestedColumns   Json                  @default("[]")
  fields             String[]
  filename           String
  runCount           Int                   @default(0)
  lastRunAt          DateTime?
  nextRunAt          DateTime?
  lockedAt           DateTime?
  lockedBy           String?
  lastSuccessAt      DateTime?
  lastFailureAt      DateTime?
  lastFailureReason  String?
  lastExportJobId    String?
  lastExportJob      ExportJob?            @relation("ScheduledExportLastExportJob", fields: [lastExportJobId], references: [id], onDelete: SetNull)
  error              String?
  isDeleted          Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  filterVersion      Int                   @default(1)
  canonicalFilterKey String?
  runs               ScheduledExportRun[]

  @@index([shop])
  @@index([shop, status])
  @@index([shop, nextRunAt])
  @@index([nextRunAt])
  @@index([status, nextRunAt])
  @@index([status, lockedAt])
  @@index([shop, canonicalFilterKey])
}

model ScheduledExportRun {
  id                String                   @id @default(cuid())
  scheduledExportId String
  shop              String
  scheduledFor      DateTime
  startedAt         DateTime?
  completedAt       DateTime?
  status            ScheduledExportRunStatus @default(PENDING)
  executionKey      String                   @unique
  errorMessage      String?
  exportJobId       String?
  fileUrl           String?
  totalItems        Int?
  durationMs        Int?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  scheduledExport   ScheduledExport          @relation(fields: [scheduledExportId], references: [id], onDelete: Cascade)

  @@index([scheduledExportId])
  @@index([shop, status])
  @@index([shop, scheduledFor])
  @@index([exportJobId])
}

model ExportJob {
  id                   String               @id @default(cuid())
  shop                 String
  filterQuery          String               @default("{}")
  executionState       String               @default("planned")
  targetSnapshotCount  Int                  @default(0)
  targetMirrorBatchId  String?
  mirrorBatchId        String?
  failureStage         String?
  filename             String
  fileName             String?
  fields               String[]
  status               String               @default("PENDING")
  fileKey              String?
  fileUrl              String?
  mimeType             String?
  fileSizeBytes        Int?
  rowCount             Int                  @default(0)
  productCount         Int                  @default(0)
  type                 String               @default("Manual export")
  isScheduled          Boolean              @default(false)
  scheduledExportId    String?
  scheduledExportRunId String?
  triggerType          ExportJobTriggerType @default(MANUAL)
  totalItems           Int?
  durationMs           Int?
  startedAt            DateTime?
  completedAt          DateTime?
  error                String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  filterVersion        Int?
  canonicalFilterKey   String?
  lastScheduledExports ScheduledExport[]    @relation("ScheduledExportLastExportJob")

  @@index([shop])
  @@index([shop, createdAt])
  @@index([shop, executionState])
  @@index([status])
  @@index([shop, status])
  @@index([scheduledExportId])
  @@index([scheduledExportRunId])
  @@index([shop, mirrorBatchId])
  @@index([shop, canonicalFilterKey])
}

model ChangeRecord {
  id                  String      @id @default(cuid())
  editHistoryId       String
  operationId         String?
  productId           String
  entityType          String?
  entityId            String?
  field               String?
  oldValue            Json?
  newValue            Json?
  mutationKey         String?
  shop                String
  options             Json?
  productFieldChanges Json?
  variantFieldChanges Json?
  image               String?
  title               String
  scope               String
  status              String      @default("pending")
  batchId             String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  editHistory         EditHistory @relation(fields: [editHistoryId], references: [id])

  @@index([editHistoryId])
  @@index([shop, operationId])
  @@index([productId])
  @@index([shop])
  @@index([status])
  @@index([batchId])
}

model FilterTrack {
  id                  String          @id @default(cuid())
  shop                String?
  filterParams        Json?
  previewFilterParams Json?
  respondProductCount Int?
  previewResCount     Int?
  type                FilterTrackType @default(filter)
  field               String?
  editOption          String?
  searchKey           String?
  replaceText         String?
  supportValue        String?
  value               Json?
  en                  String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([shop])
  @@index([type])
}

model ReferralCode {
  id           String   @id @default(cuid())
  shop         String
  referralCode String
  createdAt    DateTime @default(now())

  @@index([shop])
}

model AffiliateUser {
  id                       String   @id @default(cuid())
  name                     String
  email                    String   @unique
  referralCode             String   @unique
  referralLink             String   @unique
  numberOfReferrals        Int      @default(0)
  numberOfStoresSubscribed Int      @default(0)
  totalAmountEarned        Float    @default(0)
  phone                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([referralCode])
}

model Location {
  shop String
  id   String
  name String

  @@id([shop, id])
  @@index([shop])
}

model ErrorLog {
  id        BigInt   @id @default(autoincrement())
  shop      String
  type      String
  level     String   @default("error")
  message   String
  stack     String?
  source    String?
  request   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([type])
  @@index([level])
  @@index([source])
  @@index([createdAt])
}

model TargetSnapshot {
  id            String   @id @default(cuid())
  ownerType     String
  ownerId       String
  shop          String
  productId     String
  ordinal       Int
  mirrorBatchId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([ownerType, ownerId, productId])
  @@unique([ownerType, ownerId, ordinal])
  @@index([ownerType, ownerId])
  @@index([ownerType, ownerId, ordinal])
  @@index([shop, ownerType, createdAt])
}

model MirrorAnomaly {
  id         String   @id @default(cuid())
  shop       String
  severity   String
  type       String
  entityType String?
  entityId   String?
  message    String
  details    Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([shop, createdAt])
  @@index([shop, severity, createdAt])
  @@index([shop, type, createdAt])
}

model ShopifySession {
  id               String  @id @db.VarChar(255)
