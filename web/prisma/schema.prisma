  @@index([shop, createdAt])
}

model ScheduledEditRun {
  id              String    @id @default(cuid())
  shop            String
  scheduledEditId String
  operationId     String?
  scheduledFor    DateTime
  claimedAt       DateTime?
  claimedBy       String?
  executionKey    String?
  startedAt       DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  status          String
  targetCount     Int?
  affectedCount   Int?
  errorCode       String?
  errorMessage    String?
  executionSnapshot ScheduledEditExecutionSnapshot?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([shop, scheduledEditId, scheduledFor])
  @@unique([shop, executionKey])
  @@index([shop, status])
  @@index([shop, claimedBy])
  @@index([scheduledEditId])
}

model ScheduledEditExecutionSnapshot {
  id                       String   @id @default(cuid())
  runId                    String   @unique
  shop                     String
  scheduledEditId          String
  canonicalFilterSnapshot  Json
  canonicalRuleSnapshot    Json
  sourceTargetSnapshotId   String
  snapshotFingerprint      String
  executionPlanVersion     Int      @default(1)
  targetMirrorBatchId      String?
  targetSnapshotCount      Int      @default(0)
  totalItems               Int      @default(0)
  intentId                 String?
  mutationPlanHash         String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  run ScheduledEditRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([shop, scheduledEditId])
  @@index([shop, snapshotFingerprint])
}

