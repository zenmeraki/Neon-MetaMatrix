  parentId       String?
  replayOfOperationId String?
  snapshotSetId String?
  executionPlanId String?
  intentId       String?
  plannerVersion Int?
  compilerVersion Int?
  executionEngineVersion Int?
  idempotencyKey String
  targetHash     String?
  inputHash      String?
  resultHash     String?
  totalItems     Int                     @default(0)
  processedItems Int                     @default(0)
  failedItems    Int                     @default(0)
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  errorCode      String?
  errorMessage   String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  parent       MerchantOperation?  @relation("MerchantOperationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     MerchantOperation[] @relation("MerchantOperationHierarchy")
  replayOf     MerchantOperation?  @relation("MerchantOperationReplayLineage", fields: [replayOfOperationId], references: [id], onDelete: SetNull)
  replays      MerchantOperation[] @relation("MerchantOperationReplayLineage")
  executions   OperationExecution[]
  snapshots    TargetSnapshotSet[]
  submissions  OperationSubmission[]
  bulkEditIntents BulkEditIntent[]
  executionPlans ExecutionPlan[]
  executionPartitions ExecutionPartition[]
  exports      ExportArtifact[]
  changes      ChangeRecord[]
  immutableSnapshots ImmutableTargetSnapshotSet[]
  editHistory  EditHistory?
  exportHistory ExportHistory?
  exportJobs   ExportJob[]
  bulkUndoExecutions BulkUndoExecution[]
  spreadsheetFiles SpreadsheetFile[]
  recurringEditRuns RecurringEditRun[]
  recurringRuleRuns RecurringRuleRun[]
  scheduledExportRuns ScheduledExportRun[]

  @@unique([shop, idempotencyKey])
  @@index([shop, type, status, createdAt])
  @@index([shop, parentId])
  @@index([shop, replayOfOperationId])
  @@index([shop, snapshotSetId])
  @@index([shop, executionPlanId])
  @@index([shop, intentId])
}

