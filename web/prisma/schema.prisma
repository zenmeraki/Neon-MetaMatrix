  shop        String
  pipeline    String
  operationId String
  status      String   @default("QUEUED")
  leaseOwner  String?
  leaseExpiresAt DateTime?
  heartbeatAt DateTime?
  fencingToken BigInt?
  createdAt   DateTime @default(now())

