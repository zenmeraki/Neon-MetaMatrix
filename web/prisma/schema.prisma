}

model StoreOperationalState {
  shop                     String    @id
  mirrorSchemaVersion      Int       @default(1)
  activeCatalogBatchId     String?
  activeProductBatchId     String?
  activeVariantBatchId     String?
  activeCollectionBatchId  String?
