generator client {
  provider = "prisma-client-js"
    output   = "../generated/prisma"

}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  shop                 String
  id                   String
  title                String
  handle               String?
  status               String
  productType          String?
  vendor               String?
  tags                 String[]
  templateSuffix       String?
  description          String?
  createdAt            DateTime?
  updatedAt            DateTime?
  publishedAt          DateTime?
  seoTitle             String?
  seoDescription       String?
  totalInventory       Int?
  categoryId           String?
  categoryName         String?
  featuredImageUrl     String?
  featuredImageAltText String?
  optionsJson          Json?
  collectionsJson      Json?

   option1Name          String?
  option2Name          String?
  option3Name          String?
  variantCount         Int?      @default(0)
  visibleOnlineStore   Boolean?
  visiblePos           Boolean?

  variants             Variant[]

  @@id([shop, id])
  @@index([shop, status])
  @@index([shop, vendor])
  @@index([shop, productType])
  @@index([shop, title])
  @@index([shop, handle])
  @@index([shop, createdAt])
  @@index([shop, updatedAt])
  @@index([shop, publishedAt])
  @@index([shop, categoryName])
  @@index([shop, templateSuffix])
  @@index([shop, option1Name])
  @@index([shop, option2Name])
  @@index([shop, option3Name])
  @@index([shop, variantCount])
  @@index([shop, visibleOnlineStore])
  @@index([shop, visiblePos])
}

model Variant {
  shop                String
  id                  String
  productId           String
  title               String?
  sku                 String?
  barcode             String?

  price               Float?
  compareAtPrice      Float?
  cost                Float?

  inventoryQuantity   Int?
  inventoryPolicy     String?

  taxable             Boolean?
  taxCode             String?

  weight              Float?
  weightUnit          String?

  countryOfOrigin     String?
  hsTariffCode        String?

  position            Int?
  selectedOptionsJson Json?

   option1Value        String?
  option2Value        String?
  option3Value        String?
  tracked             Boolean?
  physicalProduct     Boolean?
  profitMargin        Float?
  inventoryLocations  Json?

  product             Product  @relation(fields: [shop, productId], references: [shop, id])

  @@id([shop, id])
  @@index([shop, sku])
  @@index([shop, price])
  @@index([shop, productId])
  @@index([shop, barcode])
   @@index([shop, title])
  @@index([shop, compareAtPrice])
  @@index([shop, cost])
  @@index([shop, inventoryQuantity])
  @@index([shop, inventoryPolicy])
  @@index([shop, taxable])
  @@index([shop, weight])
  @@index([shop, weightUnit])
  @@index([shop, countryOfOrigin])
  @@index([shop, hsTariffCode])
  @@index([shop, option1Value])
  @@index([shop, option2Value])
  @@index([shop, option3Value])
  @@index([shop, tracked])
  @@index([shop, physicalProduct])
  @@index([shop, profitMargin])
}

model SpreadsheetFile {
  id             String        @id @default(cuid())
  shop           String?
  editHistoryId  String?
  fileUrl        String?
  columnMappings Json?
  totalRows      Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  editHistories  EditHistory[]

  @@index([shop])
}

model Store {
  id                              String    @id @default(cuid())
  shopUrl                         String    @unique
  shopEmail                       String
  accessToken                     String?
  isCollectionSyncing             Boolean   @default(false)
  lastCollectionSyncAt            DateTime?
  isProductTypeSyncing            Boolean   @default(false)
  lastProductTypeSyncAt           DateTime?
  isProductInitialySyning         Boolean   @default(false)
  productInitialSyncProgress      Int       @default(0)
  shopifyBulkJobCompleted         Boolean   @default(false)
  storeTotalProducts              Int       @default(0)
  isProductSyncing                Boolean   @default(false)
  lastProductSyncAt               DateTime?
  scope                           String?   @default("")
  installedAt                     DateTime?
  unInstalledAt                   DateTime?
  isUnInstalled                   Boolean   @default(false)
  referralCode                    String?   @unique
  referralLink                    String?   @unique
  referredBy                      String?
  refIsFirstSubscriptionCompleted Boolean   @default(false)
  refSubscribedDate               DateTime?
  refRewardExpiresAt              DateTime?
  refRewarded                     Boolean   @default(false)
  refSubscribedPlanDetails        Json?
  refEarnedPrice                  Float     @default(0)
  isCreditAvailable               Boolean   @default(false)
  lastActivityAt                  DateTime?
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt

  @@index([isProductSyncing])
  @@index([lastProductSyncAt])
  @@index([isCollectionSyncing])
  @@index([lastCollectionSyncAt])
  @@index([lastProductTypeSyncAt])
  @@index([referralCode])
  @@index([referredBy])
  @@index([lastActivityAt])
  @@index([isUnInstalled])
  @@index([installedAt])
  @@index([createdAt])
}

model Subscription {
  id                    String             @id @default(cuid())
  shop                  String
  planKey               String?
  planName              String?
  subscriptionId        String?
  status                SubscriptionStatus @default(FREE)
  pendingSubscriptionId String?
  pendingPlanKey        String?
  pendingPlanName       String?
  trialEndsAt           DateTime?
  currentPeriodEnd      DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([shop])
}

model Suggestion {
  id         String   @id @default(cuid())
  email      String
  suggestion String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([email])
}

model SyncHistory {
  id                   String             @id @default(cuid())
  shop                 String
  bulkOperationId      String?
  responseUrl          String?
  status               SyncStatus         @default(processing)
  duration             Int?               @default(0)
  recordCount          Int?
  operationType        SyncOperationType?
  isInitialProductSync Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([shop, createdAt])
  @@index([shop, status])
  @@index([shop, operationType])
}

model EditHistory {
  id                String           @id @default(cuid())
  shop              String
  bulkOperationId   String?
  title             Json?
  queryFilter       String           @default("")
  editedType        String?
  rules             Json?
  affectedFields    Json?
  locationId        String?
  status            String           @default("pending")
  scheduledAt       DateTime?
  scheduledUndoAt   DateTime?
  processedCount    Int              @default(0)
  totalItems        Int              @default(0)
  totalRows         Int              @default(0)
  durationMs        Int              @default(0)
  editTime          DateTime         @default(now())
  startedAt         DateTime
  completedAt       DateTime?
  undo              Json?
  batch             Json?
  type              String?          @default("Manual edit")
  processingBatchId String?
  scheduledTask     String?
  importFileId      String?
  user              String?
  isFavourite       Boolean          @default(false)
  error             Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  changeRecords     ChangeRecord[]
  importFile        SpreadsheetFile? @relation(fields: [importFileId], references: [id])

  @@index([shop, status, type, updatedAt], map: "shop_status_type_recent")
  @@index([shop])
}

model Collection {
  id        String   @id @default(cuid())
  shop      String?
  shopifyId String?
  title     String?
  handle    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
  @@index([shop, title])
}

model ExportHistory {
  id            String    @id @default(cuid())
  shop          String
  filename      String
  filters       Json
  exportedData  String?
  status        String
  duration      String
  totalItems    Int?
  errorMessage  String?
  exportTime    DateTime?
  type          String    @default("Manual export")
  isFavourite   Boolean   @default(false)
  scheduledTask String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([shop, createdAt])
  @@index([shop, status])
  @@index([shop, isFavourite])
  @@index([shop, type])
  @@index([shop, exportTime])
}

model ExportJob {
  id          String    @id @default(cuid())
  shop        String
  filterQuery String    @default("{}")
  filename    String
  fields      String[]
  status      String    @default("PENDING")
  fileUrl     String?
  type        String    @default("Manual export")
  totalItems  Int?
  durationMs  Int?
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([shop])
  @@index([status])
}

model ChangeRecord {
  id                  String      @id @default(cuid())
  editHistoryId       String
  productId           String
  shop                String
  options             Json?
  productFieldChanges Json?
  variantFieldChanges Json?
  image               String?
  title               String
  scope               String
  status              String      @default("pending")
  batchId             String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  editHistory         EditHistory @relation(fields: [editHistoryId], references: [id])

  @@index([editHistoryId])
  @@index([productId])
  @@index([shop])
  @@index([status])
  @@index([batchId])
}

model FilterTrack {
  id                  String          @id @default(cuid())
  shop                String?
  filterParams        Json?
  previewFilterParams Json?
  respondProductCount Int?
  previewResCount     Int?
  type                FilterTrackType @default(filter)
  field               String?
  editOption          String?
  searchKey           String?
  replaceText         String?
  supportValue        String?
  value               Json?
  en                  String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([shop])
  @@index([type])
}

model ReferralCode {
  id           String   @id @default(cuid())
  shop         String
  referralCode String
  createdAt    DateTime @default(now())

  @@index([shop])
}

model AffiliateUser {
  id                       String   @id @default(cuid())
  name                     String
  email                    String   @unique
  referralCode             String   @unique
  referralLink             String   @unique
  numberOfReferrals        Int      @default(0)
  numberOfStoresSubscribed Int      @default(0)
  totalAmountEarned        Float    @default(0)
  phone                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([referralCode])
}

model Location {
  shop String
  id   String
  name String

  @@id([shop, id])
  @@index([shop])
}

model ErrorLog {
  id        BigInt   @id @default(autoincrement())
  shop      String
  type      String
  level     String   @default("error")
  message   String
  stack     String?
  source    String?
  request   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([shop])
  @@index([type])
  @@index([level])
  @@index([source])
  @@index([createdAt])
}
model ShopifySession {
  id               String  @id
  shop             String
  state            String
  isOnline         Boolean
  scope            String?
  expires          Int?
  onlineAccessInfo String?
  accessToken      String?

  @@map("shopify_sessions")
  @@index([shop])
  @@index([isOnline])
}

model ShopifySessionMigration {
  migrationName String @id @map("migration_name")

  @@map("shopify_sessions_migrations")
}
enum SubscriptionStatus {
  FREE
  PENDING
  ACTIVE
  CANCELLED
  EXPIRED
}

enum SyncStatus {
  completed
  processing
  failed
}

enum SyncOperationType {
  Collection
  ProductType
  Product
}

enum FilterTrackType {
  filter
  preview
}
