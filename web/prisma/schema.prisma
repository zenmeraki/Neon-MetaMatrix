  state            String  @db.VarChar(255)
  isOnline         Boolean
  scope            String? @db.VarChar(1024)
  expires          Int?
  onlineAccessInfo String? @db.VarChar(255)
  accessToken      String? @db.VarChar(255)

  @@map("shopify_sessions")
}

model ShopifySessionMigration {
  migrationName String @id @map("migration_name") @db.VarChar(255)

  @@map("shopify_sessions_migrations")
}

model MirrorReconcileSignal {
  id                    String    @id
  shop                  String
  entityType            String
  entityId              String
  topic                 String?
  status                String    @default("pending")
  signalCount           Int       @default(1)
  latestWebhookId       String?
  latestPayloadHash     String?
  latestEventAt         DateTime?
  latestSourceUpdatedAt DateTime?
  latestSourceKind      String?
  processingToken       String?
  processingStartedAt   DateTime?
  reconciledAt          DateTime?
  lastError             String?
