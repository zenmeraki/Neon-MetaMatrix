  merchantOperation MerchantOperation @relation(fields: [merchantOperationId], references: [id], onDelete: Cascade)

  @@unique([shop, executionKey])
  @@index([merchantOperationId, createdAt])
  @@index([shop, status])
  @@index([shop, workerJobId])
  @@index([shop, leaseOwner, leaseExpiresAt])
  @@index([shop, poisoned, status])
  @@index([shop, leaseOwner, lockVersion])
}

model OperationSubmission {
  id                  String   @id @default(cuid())
  merchantOperationId String
  shop                String
  type                OperationSubmissionType   @default(SHOPIFY_BULK_MUTATION)
  status              OperationSubmissionStatus @default(PLANNED)
  provider            String   @default("SHOPIFY")
  dispatchJobId       String?
  dispatchAttempt     Int?
  stagedUploadPath    String?
  stagedUploadUrl     String?
  bulkOperationId     String?
  resultUrl           String?
  submittedAt         DateTime?
  completedAt         DateTime?
  errorCode           String?
  errorMessage        String?
  payloadHash         String?
  submissionFingerprint String          @default("")
  payloadBytes        BigInt?
  partitionOrdinal    Int?
  resultChecksum      String?
  resultsAppliedAt    DateTime?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  merchantOperation MerchantOperation @relation(fields: [merchantOperationId], references: [id], onDelete: Cascade)

  @@unique([shop, merchantOperationId, dispatchJobId, dispatchAttempt])
  @@unique([shop, bulkOperationId])
  @@unique([shop, merchantOperationId, partitionOrdinal, submissionFingerprint])
  @@index([merchantOperationId, createdAt])
  @@index([shop, merchantOperationId, status])
  @@index([shop, bulkOperationId])
  @@index([shop, status])
  @@index([shop, merchantOperationId, partitionOrdinal])
}

model BulkEditIntent {
  id                  String   @id @default(cuid())
  shop                String
  operationId         String
  intentVersion       Int      @default(1)

  mirrorBatchId       String
  filterAst           Json
  actionAst           Json
  stableSort          Json

  canonicalIntentJson Json
  canonicalFilterHash String
  canonicalActionHash String
  intentHash          String

  plannerVersion      Int
  compilerVersion     Int
  createdAt           DateTime @default(now())

  operation MerchantOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@unique([shop, intentHash])
  @@unique([shop, operationId])
  @@index([shop, mirrorBatchId])
}

model ImmutableTargetSnapshotSet {
  id              String   @id @default(cuid())
  shop            String
  operationId     String
  intentId        String
  mirrorBatchId   String

  filterAst       Json
  actionAst       Json
  filterHash      String
  actionHash      String
  targetHash      String

  productCount    Int      @default(0)
  variantCount    Int      @default(0)

  canonicalOrderBy Json
  plannerVersion   Int
  compilerVersion  Int

  frozenAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  operation MerchantOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  targets   ImmutableTargetSnapshotItem[]

  @@unique([shop, operationId])
  @@unique([shop, intentId])
  @@index([shop, mirrorBatchId])
  @@index([shop, targetHash])
}

model ImmutableTargetSnapshotItem {
  id               String   @id @default(cuid())
  shop             String
  snapshotSetId    String
  productId        String
  variantId        String?
  ordinal          Int

  beforeValues     Json
  beforeHash       String
  beforeFingerprint String

  plannedChanges   Json?
  plannedFieldMutations Json?
  mutationFingerprint String?
  targetHash       String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  snapshotSet ImmutableTargetSnapshotSet @relation(fields: [snapshotSetId], references: [id], onDelete: Cascade)

  @@unique([shop, snapshotSetId, productId, variantId])
  @@unique([shop, snapshotSetId, ordinal])
  @@index([shop, snapshotSetId, ordinal])
  @@index([shop, productId])
  @@index([shop, variantId])
}

model ExportArtifact {
  id                  String   @id @default(cuid())
  merchantOperationId String
  shop                String
  format              String?
  storageKey          String?
  downloadUrl         String?
  exportJobId         String?
  filename            String?
  fileKey             String?
  fileUrl             String?
  mimeType            String?
  fileSizeBytes       Int?
  rowCount            Int?
  checksum            String?
  status              ExportArtifactStatus @default(PLANNED)
  createdAt           DateTime @default(now())
  completedAt         DateTime?
  updatedAt           DateTime @updatedAt

  merchantOperation MerchantOperation @relation(fields: [merchantOperationId], references: [id], onDelete: Cascade)

  @@unique([shop, exportJobId])
  @@index([shop, merchantOperationId])
  @@index([shop, status, createdAt])
  @@index([merchantOperationId, createdAt])
  @@index([shop, status])
}

model TargetSnapshotSet {
  id          String   @id @default(cuid())
  merchantOperationId String?
  operationId String
  shop        String
  intentHash  String?
  mirrorBatchId String?
  resource    String?
  targetCount Int      @default(0)
  status      String   @default("CREATED")
  entityId    String
  ordinal     Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  targets     TargetSnapshot[]
  merchantOperation MerchantOperation? @relation(fields: [merchantOperationId], references: [id], onDelete: SetNull)

  @@unique([operationId, entityId])
  @@unique([shop, intentHash, mirrorBatchId])
  @@index([shop, operationId])
  @@index([shop, merchantOperationId])
  @@index([shop, mirrorBatchId])
  @@index([shop, status])
  @@index([operationId, entityId])
  @@index([operationId, ordinal])
}

model ExecutionPlan {
  id            String   @id @default(cuid())
  shop          String
  operationId   String
  intentHash    String
  snapshotSetId String
  mirrorBatchId String
  status        String   @default("CREATED")
  mutationCount Int      @default(0)
  partitionCount Int     @default(0)
  estimatedMutationBytes BigInt?
  plannerVersion Int
  planHash      String
  planJson      Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  operation MerchantOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  partitions ExecutionPartition[]

  @@unique([shop, operationId, intentHash, snapshotSetId])
  @@index([shop, operationId])
  @@index([shop, status])
}

model ExecutionPartition {
  id                    String   @id @default(cuid())
  shop                  String
  operationId           String
  executionPlanId       String

  ordinal               Int
  status                String

  targetStartOrdinal    Int
  targetEndOrdinal      Int

  estimatedBytes        BigInt?
  actualBytes           BigInt?

  payloadHash           String
  resultChecksum        String?

  stagedUploadPath      String?
  bulkOperationId       String?

  submittedAt           DateTime?
  completedAt           DateTime?

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  operation             MerchantOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  executionPlan         ExecutionPlan     @relation(fields: [executionPlanId], references: [id], onDelete: Cascade)

  @@unique([shop, executionPlanId, ordinal])
  @@index([shop, operationId])
  @@index([shop, status])
}

model VerificationResult {
  id                  String   @id @default(cuid())
  shop                String
  operationId         String
  partitionId         String?
  expectedFingerprint String
  actualFingerprint   String
  verified            Boolean
  mismatchReason      String?
