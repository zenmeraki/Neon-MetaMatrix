  @@index([status, createdAt])
}

model StoreOperation {
  id                String    @id @default(cuid())
  shop              String
  type              String
  status            String
  requestedBy       String?
  source            String
  lockKey           String?
  leaseOwner        String?
  leaseExpiresAt    DateTime?
