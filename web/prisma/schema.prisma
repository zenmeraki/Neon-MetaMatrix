enum MerchantOperationStatus {
  PLANNED
  SNAPSHOTTING
  SNAPSHOTTED
  DISPATCHING
  AWAITING_SHOPIFY
  APPLYING_RESULTS
  VERIFYING
  COMPLETED
  FAILED
  CANCELLED
}

